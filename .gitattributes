# Default: let Git normalize text files to LF in the repo and check them out
# with the platform's native line endings. Stops the "LF will be replaced by
# CRLF" warnings on Windows.
* text=auto

# Normalize line endings. Shell scripts MUST stay LF so they run on Linux/macOS
# regardless of the platform they were checked out on; Windows scripts stay CRLF.
*.sh   text eol=lf
*.ps1  text eol=crlf
*.bat  text eol=crlf

# Treat common binaries as binary (no EOL/diff munging).
*.png  binary
*.jpg  binary
*.pdf  binary
*.xlsx binary
*.xlsm binary
*.exe  binary
